# === Kalshi ===
KALSHI_API_KEY=your_kalshi_api_key_here
KALSHI_PRIVATE_KEY_PATH=./keys/kalshi_private.pem

# === OpenAI ===
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_OUTPUT_TOKENS=180
OPENAI_DAILY_TOKEN_BUDGET=120000

# === AI Scanner Cost Controls ===
SCANNER_ENABLED=true
SCANNER_MODE=off
SCANNER_PESSIMISTIC_MODE=true
SCANNER_MIN_EDGE=0.10
SCANNER_INTERVAL_SECONDS=300
SCANNER_MAX_MARKETS_PER_SCAN=3
SCANNER_CACHE_TTL_SECONDS=1800
SCANNER_MARKET_COOLDOWN_SECONDS=21600
SCANNER_MAX_CALLS_PER_HOUR=24
SCANNER_MIN_VOLUME=25

# === Transcript Sniper ===
TRANSCRIPT_ENABLE_WHISPER=false

# === Linguistic Sniper (OpenAI Chat) ===
LINGUISTIC_ENABLED=false

# === Bot Settings ===
PAPER_TRADING=true
LOG_LEVEL=INFO
SESSION_TAKEOVER_EXISTING=true

# === Risk Parameters ===
MAX_POSITION_PCT=0.03
MAX_SECTOR_PCT=0.30
MAX_DRAWDOWN_PCT=0.15
KELLY_FRACTION=0.25
MIN_SIGNAL_CONFIDENCE=0.20
RISK_TEST_MODE=true
TEST_MAX_POSITION_PCT=0.10
TEST_MAX_DRAWDOWN_PCT=0.35
TEST_KELLY_FRACTION=0.75
TRADE_JOURNAL_ENABLED=true
MIN_EDGE_THRESHOLD=0.02
